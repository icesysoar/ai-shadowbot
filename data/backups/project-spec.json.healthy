      "example": "https://api.openai.com/v1 或 http://localhost:11434/v1"
    },
    {
      "key": "LLM_MODEL",
      "description": "使用的模型名",
      "required": false,
      "example": "gpt-4o"
    },
    {
      "key": "SCREEN_MASK_SENSITIVE",
      "description": "截图外发前是否对敏感区（密码框/账号/剪贴板）脱敏打码，默认 true",
      "required": false,
      "example": "true"
    }
